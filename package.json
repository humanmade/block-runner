{
  "name": "block-runner",
  "version": "0.1.0",
  "description": "Deterministic CLI and library for converting design HTML into valid native Gutenberg block markup.",
  "type": "module",
  "license": "GPL-2.0-or-later",
  "bin": {
    "block-runner": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples"
  ],
  "engines": {
    "node": ">=18.12.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "check:private": "node scripts/check-private-refs.mjs",
    "verify": "npm run typecheck && npm test && npm run build && npm run check:private && npm run pack:check"
  },
  "dependencies": {
    "@wordpress/block-library": "9.26.0",
    "@wordpress/blocks": "14.15.0",
    "commander": "12.1.0",
    "fast-glob": "3.3.3",
    "jsdom": "24.1.3"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "overrides": {
    "uuid": "9.0.1"
  }
}
